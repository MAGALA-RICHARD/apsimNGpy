                "",
                "namespace Models",
                "{",
                "    [Serializable] ",
                "    public class Script : Model",
                "    {",
                "        [Link] IClock Clock;",
                "        ",
                "        [Separator(\"Harvesting script that forces harvesting\")]",
                "        [Description(\"Crop\")]",
                "        public IPlant Crop { get; set; }",
                "        ",
                "        [Description(\"Date to force harvesting by if crop is not ready (d-mmm)\")]",
                "        public string Date { get; set; }",
                "        ",
                "        [EventSubscribe(\"DoManagement\")]",
                "        private void OnDoManagement(object sender, EventArgs e)",
                "        {",
                "            if (Crop.IsReadyForHarvesting || ",
                "                (DateUtilities.DatesAreEqual(Date, Clock.Today) && Crop.IsAlive))",
                "            {",
                "                Crop.Harvest();",
                "                Crop.EndCrop();",
                "            }",
                "        }",
                "    }",

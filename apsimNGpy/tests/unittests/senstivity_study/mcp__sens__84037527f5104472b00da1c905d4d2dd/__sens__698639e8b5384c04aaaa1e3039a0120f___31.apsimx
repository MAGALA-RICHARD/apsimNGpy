              "$type": "Models.Manager, Models",
              "CodeArray": [
                "using Models.Soils;",
                "using System;",
                "using Models.Core;",
                "using Models.PMF;",
                "using APSIM.Shared.Utilities;",
                "namespace Models",
                "{",
                "    [Serializable]",
                "    public class Script : Model",
                "    {",
                "        [Link] Clock Clock;",
                "        ",
                "        [Link] Fertiliser Fertiliser;",
                "        [Link] ISummary Summary;",
                "        [Separator(\"Crop in the rotation to apply fertilizers\")]",
                "        [Description(\"Crop\")]",
                "        public IPlant Crop { get; set; }",
                "        ",
                "        [Separator(\"Fertilizer application details\")]",
                "",
                "        [Description(\"Type of fertiliser to apply? Select from a list. \")] ",
                "        [Display(Type = DisplayType.FertiliserType)]public string FertiliserType { get; set; }",
                "        ",
                "        [Description(\"Fraction to apply at sowing (0-1). if it is a single application, it should be 1\")]",
                "        public double Fraction { get; set; }",
                "",
                "        [Description(\"Enter the total amount of fertiliser to be applied (kg /ha)\")] ",
                "        public double Amount { get; set; }",
                "        ",
                "        [Description(\"Enter other dates as dd-mmm with comma separation (any year information entered will be ignored): \")] ",
                "        public string[] FertiliserDates { get; set; } ",
                "        ",
                "        [Description(\"Is the remaining amount to be applied each time? (true/ticked)? Or is it the total annual amount across all dates (no(false)/unticked)\")] ",
                "        public bool AmountType { get; set; }",
                "        ",
                "        [EventSubscribe(\"Sowing\")]",
                "        private void OnSowing(object sender, EventArgs e)",
                "        {",
                "            Model crop = sender as Model;",
                "            var nit = Fraction * Amount;",
                "            if (Crop != null && crop.Name.ToLower() == (Crop as IModel).Name.ToLower())",
                "                Fertiliser.Apply(amount: nit, type: FertiliserType);",
                "        }",
                "        ",
                "        [EventSubscribe(\"DoManagement\")]",
                "        private void OnDoManagement(object sender, EventArgs e)",
                "        {",
                "            foreach (string ddMMM in FertiliserDates)",
                "            {",
                "             var nit = Fraction * Amount;",
                "             var otherNapp = Amount - nit;",
                "                if (Crop.IsAlive & DateUtilities.DatesEqual(ddMMM, Clock.Today))",
                "                {",
                "                    if (AmountType)",
                "                        Fertiliser.Apply(amount: otherNapp, type: FertiliserType);",
                "                        ",
                "                    else",
                "                        Fertiliser.Apply(amount: otherNapp / FertiliserDates.Length, type: FertiliserType);",
                "                        Summary.WriteMessage(this, $\"At other date(s), {Crop.Name} received {otherNapp} Kg of Nitrogen applied as {FertiliserType}. {AmountType} was selected: true implies that the user specified amount was applied on each date and false implies that the amount was applied across dates\", MessageType.Information);",
                "                }",
                "            }",
                "        }",
                "    }",
                "}"
              ],
